# Copy to .env.local and fill in values

# Backend API URL (local: wrangler dev, prod: your workers.dev URL)
EXPO_PUBLIC_API_URL=http://localhost:8787

# Google OAuth Client IDs (https://console.cloud.google.com → Credentials)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_web_client_id_here
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id_here
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id_here
